{
  "name": "ip-speil",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "bun src/server/index.ts",
    "dev": "bun run build && bun --watch src/server/index.ts",
    "build": "bun build src/client/main.ts --outdir public/assets/js --target browser --minify --sourcemap=linked",
    "build:watch": "bun build src/client/main.ts --outdir public/assets/js --target browser --sourcemap=linked --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p src/client/tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run build && bun run typecheck && bun run lint && bun test"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "dependencies": {
    "hono": "^4.12.31"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
